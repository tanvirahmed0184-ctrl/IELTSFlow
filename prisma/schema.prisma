generator client {
  provider        = "prisma-client"
  output          = "../lib/generated/prisma"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [vector]
}

enum UserRole {
  GUEST
  STUDENT
  INSTRUCTOR
  ADMIN
  SUPER_ADMIN
}

enum TestModule {
  LISTENING
  READING
  WRITING
  SPEAKING
}

enum TestVariant {
  ACADEMIC
  GENERAL
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum QuestionType {
  MULTIPLE_CHOICE
  FILL_IN_BLANK
  TRUE_FALSE_NOT_GIVEN
  YES_NO_NOT_GIVEN
  MATCHING
  SENTENCE_COMPLETION
  SHORT_ANSWER
  DIAGRAM_LABELLING
  SUMMARY_COMPLETION
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  PAST_DUE
  TRIALING
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  role      UserRole @default(STUDENT)
  avatarUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  testAttempts        TestAttempt[]
  writingAttempts     WritingAttempt[]
  speakingAttempts    SpeakingAttempt[]
  bookingsAsStudent   Booking[]          @relation("StudentBookings")
  bookingsAsInstructor Booking[]         @relation("InstructorBookings")
  availability        InstructorAvailability[]
  subscription        Subscription?
  progressRecords     ProgressRecord[]

  @@map("users")
}

model Test {
  id          String      @id @default(cuid())
  title       String
  description String?
  module      TestModule
  variant     TestVariant
  difficulty  Difficulty  @default(MEDIUM)
  isActive    Boolean     @default(true)
  isGenerated Boolean     @default(false)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  sections     TestSection[]
  testAttempts TestAttempt[]

  @@map("tests")
}

model TestSection {
  id        String  @id @default(cuid())
  testId    String
  title     String
  passage   String?
  audioUrl  String?
  order     Int

  test      Test       @relation(fields: [testId], references: [id], onDelete: Cascade)
  questions Question[]

  @@map("test_sections")
}

model Question {
  id            String       @id @default(cuid())
  sectionId     String
  type          QuestionType
  question      String
  options       Json?
  correctAnswer String
  explanation   String?
  order         Int

  section TestSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  answers Answer[]

  @@map("questions")
}

model TestAttempt {
  id          String    @id @default(cuid())
  userId      String
  testId      String
  startedAt   DateTime  @default(now())
  completedAt DateTime?
  score       Float?
  bandScore   Float?

  user    User     @relation(fields: [userId], references: [id])
  test    Test     @relation(fields: [testId], references: [id])
  answers Answer[]

  @@map("test_attempts")
}

model Answer {
  id            String @id @default(cuid())
  attemptId     String
  questionId    String
  answer        String
  isCorrect     Boolean?

  attempt  TestAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question Question    @relation(fields: [questionId], references: [id])

  @@map("answers")
}

model WritingAttempt {
  id          String    @id @default(cuid())
  userId      String
  taskType    String
  prompt      String
  response    String
  wordCount   Int
  submittedAt DateTime  @default(now())
  evaluation  Json?
  bandScore   Float?

  user User @relation(fields: [userId], references: [id])

  @@map("writing_attempts")
}

model SpeakingAttempt {
  id           String    @id @default(cuid())
  userId       String
  part         Int
  topic        String
  audioUrl     String?
  transcript   String?
  duration     Int?
  submittedAt  DateTime  @default(now())
  evaluation   Json?
  bandScore    Float?

  user User @relation(fields: [userId], references: [id])

  @@map("speaking_attempts")
}

model Resource {
  id          String   @id @default(cuid())
  title       String
  fileUrl     String
  fileType    String
  module      TestModule?
  topic       String?
  difficulty  Difficulty?
  variant     TestVariant?
  sourceType  String?
  extractedText String?
  isProcessed Boolean  @default(false)
  createdAt   DateTime @default(now())

  chunks ResourceChunk[]

  @@map("resources")
}

model ResourceChunk {
  id         String                   @id @default(cuid())
  resourceId String
  content    String
  embedding  Unsupported("vector(768)")?
  metadata   Json?

  resource Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@map("resource_chunks")
}

model InstructorAvailability {
  id           String   @id @default(cuid())
  instructorId String
  dayOfWeek    Int
  startTime    String
  endTime      String
  isActive     Boolean  @default(true)

  instructor User @relation(fields: [instructorId], references: [id])

  @@map("instructor_availability")
}

model Booking {
  id           String        @id @default(cuid())
  studentId    String
  instructorId String
  scheduledAt  DateTime
  duration     Int           @default(15)
  status       BookingStatus @default(PENDING)
  meetingLink  String?
  notes        String?
  score        Json?
  createdAt    DateTime      @default(now())

  student    User @relation("StudentBookings", fields: [studentId], references: [id])
  instructor User @relation("InstructorBookings", fields: [instructorId], references: [id])

  @@map("bookings")
}

model Subscription {
  id               String             @id @default(cuid())
  userId           String             @unique
  stripeCustomerId String?
  stripePriceId    String?
  stripeSubId      String?
  status           SubscriptionStatus @default(TRIALING)
  currentPeriodEnd DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@map("subscriptions")
}

model ProgressRecord {
  id        String   @id @default(cuid())
  userId    String
  module    TestModule
  bandScore Float
  date      DateTime @default(now())
  metadata  Json?

  user User @relation(fields: [userId], references: [id])

  @@map("progress_records")
}
